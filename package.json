{
  "name": "digg-button-classic",
  "version": "1.0.0",
  "description": "Classic Digg-style vote buttons with multiple themes",
  "author": "contact@findweedny.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/FindWeedNY/digg-button-classic"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "lint": "eslint *.js chrome/*.js --no-error-on-unmatched-pattern",
    "format": "prettier --write \"*.js\" \"chrome/*.js\" --ignore-path .gitignore",
    "format:check": "prettier --check \"*.js\" \"chrome/*.js\" --ignore-path .gitignore",
    "build": "./build.sh",
    "ci": "npm run format:check && npm run lint && npm run test && npm run build"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.8.1"
  }
}
